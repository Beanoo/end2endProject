@@ -0,0 +1,34 @@
+import Markdown from "markdown-to-jsx";
+import { useEffect, useState } from "react";
+import { useLocation, useParams } from "react-router-dom";
+import { useAuth } from "../../context/AuthContext";
+import getProfile from "../../services/getProfile";
+
+function ProfileAboutMe() {
+  const { state } = useLocation();
+  const [profile, setProfile] = useState(state || {});
+  const { headers } = useAuth();
+  const { username } = useParams();
+
+  useEffect(() => {
+    if (state && state.bio !== undefined) return;
+
+    getProfile({ headers, username })
+      .then(setProfile)
+      .catch(console.error);
+  }, [username, headers, state]);
+
+  const { bio } = profile;
+
+  return (
+    <div className="article-preview">
+      {bio ? (
+        <Markdown options={{ forceBlock: true }}>{bio}</Markdown>
+      ) : (
+        <p className="text-muted text-xs-center">该用户暂未填写个人简介</p>
+      )}
+    </div>
+  );
+}
+
+export default ProfileAboutMe;
