+import { useLocation, useParams } from "react-router-dom";
+import { useAuth } from "../../context/AuthContext";
+
+function ProfileAboutMe() {
+  const { state } = useLocation();
+  const { username } = useParams();
+  const { loggedUser } = useAuth();
+
+  const bio = state?.bio;
+  const isProfileOwner = loggedUser?.username === username;
+
+  return (
+    <div className="profile-about-me mt-4">
+      <div className="p-4 bg-light rounded">
+        <div className="d-flex align-items-center justify-content-between mb-3">
+          <h4 className="mb-0">About Me</h4>
+          {isProfileOwner && (
+            <button className="btn btn-sm btn-outline-secondary">
+              <i className="ion-edit mr-1"></i>编辑简介
+            </button>
+          )}
+        </div>
+        <p className="text-muted mb-0" style={{ whiteSpace: "pre-line" }}>
+          {bio || "该用户暂未填写个人简介"}
+        </p>
+      </div>
+    </div>
+  );
+}
+
+export default ProfileAboutMe;
