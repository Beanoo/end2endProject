@@ -0,0 +1,13 @@
+export default function getArticleStats(body) {
+  if (!body) return { totalWords: 0, readingMinutes: 0 };
+  // 清理markdown特殊标记后统计有效字符数
+  const plainText = body
+    .replace(/[#*`\[\]()\-!>]/g, '')
+    .replace(/\s+/g, ' ')
+    .trim();
+  const totalWords = plainText.length;
+  // 按平均每分钟300字阅读速度计算，最低阅读时长为1分钟
+  const readingMinutes = totalWords === 0 ? 0 : Math.max(1, Math.ceil(totalWords / 300));
+  return { totalWords, readingMinutes };
+}
