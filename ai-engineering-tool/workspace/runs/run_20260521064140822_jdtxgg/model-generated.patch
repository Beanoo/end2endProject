@@ -0,0 +1,18 @@
+import getArticleStats from './articleStats';
+
+describe('getArticleStats utility', () => {
+  it('returns zero stats for empty/non-existent body', () => {
+    expect(getArticleStats('')).toEqual({ totalWords: 0, readingMinutes: 0 });
+    expect(getArticleStats(null)).toEqual({ totalWords: 0, readingMinutes: 0 });
+    expect(getArticleStats(undefined)).toEqual({ totalWords: 0, readingMinutes: 0 });
+  });
+
+  it('returns 1 minute reading time for short content', () => {
+    const shortBody = '这是一段测试用的短文章内容';
+    const result = getArticleStats(shortBody);
+    expect(result.totalWords).toBe(11);
+    expect(result.readingMinutes).toBe(1);
+  });
+
+  it('calculates correct reading time for 600+ character content', () => {
+    const longBody = '测'.repeat(650);
+    expect(getArticleStats(longBody).readingMinutes).toBe(3);
+  });
+});
