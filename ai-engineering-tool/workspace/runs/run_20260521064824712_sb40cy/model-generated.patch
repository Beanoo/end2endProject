@@ -0,0 +1,13 @@
+export default function getArticleStats(body) {
+  if (!body) {
+    return { totalWords: 0, estimatedMinutes: 0 };
+  }
+  // 移除基础Markdown标记后统计纯文本字数
+  const plainText = body.replace(/[#*`\[\]()\-!~>]/g, '').replace(/\s+/g, ' ').trim();
+  const totalWords = plainText.length;
+  // 按平均每分钟200字计算阅读时长，向上取整，最少1分钟
+  const estimatedMinutes = totalWords === 0 ? 0 : Math.max(1, Math.ceil(totalWords / 200));
+  return { totalWords, estimatedMinutes };
+}
+
