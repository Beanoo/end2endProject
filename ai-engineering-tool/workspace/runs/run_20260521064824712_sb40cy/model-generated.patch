@@ -0,0 +1,21 @@
+import getArticleStats from './articleStats';
+
+describe('getArticleStats utility', () => {
+  it('returns zero stats for empty/non-existent body', () => {
+    expect(getArticleStats('')).toEqual({ totalWords: 0, estimatedMinutes: 0 });
+    expect(getArticleStats(null)).toEqual({ totalWords: 0, estimatedMinutes: 0 });
+    expect(getArticleStats(undefined)).toEqual({ totalWords: 0, estimatedMinutes: 0 });
+  });
+
+  it('returns 1 minute estimated reading time for short content', () => {
+    const shortBody = 'This is a short test article content.';
+    const stats = getArticleStats(shortBody);
+    expect(stats.totalWords).toBeGreaterThan(0);
+    expect(stats.estimatedMinutes).toBe(1);
+  });
+
+  it('calculates correct reading time for long content', () => {
+    const longBody = '中文字符测试内容'.repeat(100);
+    expect(getArticleStats(longBody).estimatedMinutes).toBe(3);
+  });
+});
