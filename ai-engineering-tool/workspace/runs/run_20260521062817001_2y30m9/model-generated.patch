+import { getArticleStats } from './articleStats';
+
+describe('getArticleStats', () => {
+  it('returns zero stats for invalid/empty input', () => {
+    expect(getArticleStats('')).toEqual({ wordCount: 0, readingMinutes: 0 });
+    expect(getArticleStats(null)).toEqual({ wordCount: 0, readingMinutes: 0 });
+    expect(getArticleStats(undefined)).toEqual({ wordCount: 0, readingMinutes: 0 });
+  });
+
+  it('calculates correct total word count excluding whitespace', () => {
+    const testBody = 'Hello world\n 中文测试内容';
+    expect(getArticleStats(testBody).wordCount).toBe(12);
+  });
+
+  it('calculates expected reading minutes correctly (200 chars per minute)', () => {
+    expect(getArticleStats('a'.repeat(100)).readingMinutes).toBe(1);
+    expect(getArticleStats('a'.repeat(250)).readingMinutes).toBe(2);
+    expect(getArticleStats('a'.repeat(400)).readingMinutes).toBe(2);
+    expect(getArticleStats('a'.repeat(401)).readingMinutes).toBe(3);
+  });
+});