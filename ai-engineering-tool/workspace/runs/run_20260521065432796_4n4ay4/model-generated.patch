+export const getArticleStats = (body = '') => {
+  // 清理基础Markdown格式标记
+  const cleanedContent = body
+    .replace(/[#*`_~>\[\]()!-]/g, '')
+    .replace(/\s+/g, ' ')
+    .trim();
+
+  // 统计中文字符数 + 英文单词数
+  const chineseCharCount = (cleanedContent.match(/[\u4e00-\u9fa5]/g) || []).length;
+  const englishWordCount = (cleanedContent.match(/[a-zA-Z]+/g) || []).length;
+  const totalWordCount = chineseCharCount + englishWordCount;
+
+  // 按每分钟200字/词计算阅读时长，最少1分钟
+  const estimatedReadingMinutes = totalWordCount <= 0 ? 1 : Math.ceil(totalWordCount / 200);
+  return { wordCount: totalWordCount, readingTimeMinutes: estimatedReadingMinutes };
+};
