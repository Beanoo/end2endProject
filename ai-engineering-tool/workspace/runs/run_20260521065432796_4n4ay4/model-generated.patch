+import { getArticleStats } from './articleStats';
+
+describe('getArticleStats utility', () => {
+  it('returns default valid stats for empty input', () => {
+    expect(getArticleStats('')).toEqual({ wordCount: 0, readingTimeMinutes: 1 });
+  });
+
+  it('correctly counts Chinese characters', () => {
+    const testBody = '这是一段用于测试的中文内容';
+    expect(getArticleStats(testBody).wordCount).toBe(11);
+  });
+
+  it('correctly counts English words', () => {
+    const testBody = 'Hello world test article stats calculation';
+    expect(getArticleStats(testBody).wordCount).toBe(6);
+  });
+
+  it('calculates reading time correctly', () => {
+    const longBody = '测'.repeat(400);
+    expect(getArticleStats(longBody).readingTimeMinutes).toBe(2);
+  });
+});
