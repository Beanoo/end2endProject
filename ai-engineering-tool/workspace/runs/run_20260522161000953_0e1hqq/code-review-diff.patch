index 0000000..996d35a
--- /dev/null
+++ b/frontend/src/routes/Profile/ProfileAboutMe.jsx
@@ -0,0 +1,34 @@
+import { useState, useEffect } from "react";
+import { useParams } from "react-router-dom";
+import { useAuth } from "../../context/AuthContext";
+import getProfile from "../../services/getProfile";
+
+function ProfileAboutMe() {
+  const { username } = useParams();
+  const { headers } = useAuth();
+  const [bio, setBio] = useState("");
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    setLoading(true);
+    getProfile({ username, headers })
+      .then(res => setBio(res.profile.bio || ""))
+      .finally(() => setLoading(false));
+  }, [username, headers]);
+
+  return (
+    <div className="profile-about-me">
+      <div className="article-preview">
+        {loading ? (
+          <em>Loading profile info...</em>
+        ) : bio && bio.trim() ? (
+          <p style={{ whiteSpace: "pre-wrap" }}>{bio}</p>
+        ) : (
+          <em>该用户暂未填写个人简介</em>
+        )}
+      </div>
+    </div>
+  );
+}
+
+export default ProfileAboutMe;
