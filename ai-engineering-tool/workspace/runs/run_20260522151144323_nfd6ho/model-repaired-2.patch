diff --git a/frontend/src/routes/Profile/ProfileAboutMe.jsx b/frontend/src/routes/Profile/ProfileAboutMe.jsx
--- /dev/null
+++ b/frontend/src/routes/Profile/ProfileAboutMe.jsx
@@ -0,0 +1,32 @@
+import { useState, useEffect } from "react";
+import { useParams } from "react-router-dom";
+import agent from "../../services/agent";
+
+function ProfileAboutMe() {
+  const { username } = useParams();
+  const [profile, setProfile] = useState(null);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    setLoading(true);
+    agent.Profile.get(username).then(res => {
+      setProfile(res.profile);
+      setLoading(false);
+    });
+  }, [username]);
+
+  if (loading) {
+    return (
+      <div className="article-preview">
+        <em>Loading profile info...</em>
+      </div>
+    );
+  }
+
+  const bio = profile?.bio;
+
+  return (
+    <div className="about-me-content" style={{ whiteSpace: "pre-wrap", padding: "1rem 0" }}>
+      {!bio || bio.trim() === "" ? (
+        <p className="text-muted">该用户暂未填写个人简介</p>
+      ) : (
+        <p>{bio}</p>
+      )}
+    </div>
+  );
+}
+
+export default ProfileAboutMe;
